<svg viewBox="0 0 760 200" xmlns="http://www.w3.org/2000/svg" width="760" height="200">
<defs>
  <style>
    .abar { animation: rise 1.2s cubic-bezier(.22,.61,.36,1) both; transform-origin: bottom center; }
    .abar:nth-child(odd)  { animation-delay: calc(var(--i) * 0.04s); }
    .abar:nth-child(even) { animation-delay: calc(var(--i) * 0.04s + 0.02s); }
    @keyframes rise { from{transform:scaleY(0);opacity:0;} to{transform:scaleY(1);opacity:1;} }
    .glowline { animation: glowPulse 2s ease-in-out infinite alternate; }
    @keyframes glowPulse { from{opacity:.3;} to{opacity:.9;} }
    .title-blink { animation: blink 1.8s step-end infinite; }
    @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.2;} }
  </style>
  <linearGradient id="ag1" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="#00ff88"/>
    <stop offset="100%" stop-color="#00ff8833"/>
  </linearGradient>
  <linearGradient id="ag2" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="#a855f7"/>
    <stop offset="100%" stop-color="#a855f733"/>
  </linearGradient>
  <linearGradient id="ag3" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="#38bdf8"/>
    <stop offset="100%" stop-color="#38bdf833"/>
  </linearGradient>
  <filter id="glow2">
    <feGaussianBlur stdDeviation="2.5" result="b"/>
    <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
  </filter>
</defs>

